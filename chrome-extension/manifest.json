{
  "manifest_version": 3,
  "name": "TrustVault Autofill",
  "version": "1.0.0",
  "description": "Secure password autofill from TrustVault PWA",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://trust-vault-pwa.vercel.app/*",
    "http://localhost:3000/*"
  ],
  "background": {
    "service_worker": "scripts/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://*/*"],
      "js": ["scripts/content.js"],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": [
        "https://trust-vault-pwa.vercel.app/*",
        "http://localhost:3000/*"
      ],
      "js": ["scripts/vault-bridge.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
