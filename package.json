{
  "name": "trustvault-pwa",
  "version": "1.0.0",
  "description": "TrustVault - Enterprise-grade security-first credential manager PWA with OWASP Mobile Top 10 2025 compliance",
  "type": "module",
  "private": true,
  "overrides": {
    "uuid": "^11.1.1",
    "esbuild": "^0.28.1"
  },
  "scripts": {
    "dev": "vite --host",
    "dev:https": "vite --host --https",
    "build": "tsc && vite build && node scripts/inject-sw-version.js",
    "build:deploy": "vite build",
    "preview": "vite preview --host",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,css}\"",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch",
    "security:audit": "npm audit --audit-level=moderate",
    "docs:verify": "bash scripts/doc-verify.sh",
    "pwa:build": "vite build --mode production",
    "pwa:icons": "node scripts/generate-icons.js",
    "lighthouse": "lighthouse http://localhost:4173 --view",
    "analyze:bundle": "vite build && du -sh dist/assets/js/*.js | sort -h",
    "ocr:assets": "node scripts/copy-ocr-assets.js",
    "litert:assets": "node scripts/copy-litert-assets.js",
    "cap:sync": "npm run build && cap sync android && node scripts/inject-csp-for-capacitor.js",
    "cap:android": "npm run build && cap sync android && node scripts/inject-csp-for-capacitor.js && cap open android",
    "predev": "node scripts/copy-ocr-assets.js && node scripts/copy-litert-assets.js",
    "prebuild": "node scripts/copy-ocr-assets.js && node scripts/copy-litert-assets.js",
    "prebuild:deploy": "node scripts/copy-ocr-assets.js && node scripts/copy-litert-assets.js",
    "prepreview": "node scripts/copy-ocr-assets.js && node scripts/copy-litert-assets.js"
  },
  "dependencies": {
    "@capacitor-community/image-to-text": "^8.0.0",
    "@capacitor/android": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@emotion/react": "^11.13.5",
    "@emotion/styled": "^11.13.5",
    "@jcesarmobile/capacitor-ocr": "^0.3.0",
    "@litert-lm/core": "^0.13.1",
    "@mlc-ai/web-llm": "^0.2.84",
    "@mui/icons-material": "^6.1.7",
    "@mui/material": "^6.1.7",
    "@noble/hashes": "^1.5.0",
    "@simplewebauthn/browser": "^10.0.0",
    "@simplewebauthn/types": "^12.0.0",
    "chroncraft": "^0.2.1",
    "dexie": "^4.0.11",
    "dompurify": "^3.4.11",
    "driver.js": "^1.3.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.18.0",
    "tesseract.js": "^5.1.1",
    "zod": "^3.23.8",
    "zustand": "^5.0.2",
    "zxcvbn": "^4.4.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@eslint/js": "^9.38.0",
    "@tesseract.js-data/eng": "^1.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^22.10.1",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "@types/zxcvbn": "^4.4.5",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.6",
    "@vitest/ui": "^4.1.6",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "fake-indexeddb": "^6.2.4",
    "globals": "^16.4.0",
    "jsdom": "^25.0.1",
    "lighthouse": "^12.2.1",
    "png-to-ico": "^3.0.1",
    "prettier": "^3.3.3",
    "sharp": "^0.34.5",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.46.2",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^4.1.6",
    "workbox-window": "^7.3.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "browserslist": {
    "production": [
      "last 2 chrome versions",
      "last 2 firefox versions",
      "last 2 safari versions",
      "last 2 edge versions"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
